# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Production: connect as the non-owner billinx_app role so that FORCE ROW LEVEL
# SECURITY is enforced by Postgres for every tenant-scoped query.
# Dev: using the superuser here is fine because FORCE RLS is in effect and the
# app explicitly opts out via SET LOCAL row_security = OFF inside asAdmin().
DATABASE_URL=postgresql://billinx:billinx_secret@localhost:5432/billinx
# Connection pool settings — append to DATABASE_URL as query params for production:
#   ?connection_limit=10&pool_timeout=20
# Recommended: connection_limit=10 for production ECS tasks, 3 for dev
DB_POOL_SIZE=10

# Owner-role connection used for:
#   1. npx prisma migrate deploy (DDL requires owner privileges)
#   2. PrismaService.asAdmin() — SET LOCAL row_security = OFF requires superuser
# In production this must be a different, more-privileged user than DATABASE_URL.
# In dev both can point to the same superuser account.
MIGRATION_DATABASE_URL=postgresql://billinx:billinx_secret@localhost:5432/billinx

# Postgres service vars (used by docker-compose; DATABASE_URL is built from these)
POSTGRES_DB=billinx
POSTGRES_USER=billinx
POSTGRES_PASSWORD=billinx_secret
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_URL takes precedence over the individual host/port/password values below.
# Use it for TLS/ElastiCache in production:
#   rediss://:AUTH_TOKEN@your-cluster.cache.amazonaws.com:6379
# redis:// (no TLS) or rediss:// (TLS) are both supported.
# REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank to disable Redis auth in development
# REDIS_PASSWORD=
# Set to false only for AWS ElastiCache clusters in regions that use self-signed
# TLS certificates. Leave unset (defaults to strict validation) for all other cases.
# REDIS_TLS_REJECT_UNAUTHORIZED=false

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change both secrets before deploying to production (64+ char hex strings)
JWT_SECRET=billinx-dev-secret-change-in-production
ADMIN_JWT_SECRET=billinx-admin-secret-change-in-production
# Redis AOF persistence mode. Set to "appendonly" for production durability.
# With appendonly enabled, BullMQ jobs survive Redis restarts (power failures).
# On AWS ElastiCache enable AOF via parameter group (appendonly=yes).
REDIS_PERSISTENCE=appendonly
# Comma-separated IPs or CIDR ranges allowed to reach /v1/admin routes.
# Leave unset in local dev (all IPs allowed with a warning). Set in production.
# Example: ADMIN_ALLOWED_IPS=10.0.0.0/8,203.0.113.42
ADMIN_ALLOWED_IPS=
# JWT token lifetimes (s=seconds, m=minutes, h=hours, d=days)
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES (email delivery) — can use a different region from the main account
AWS_SES_REGION=us-east-1

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_FROM=Billinx <noreply@billinx.ng>
# Base URL used to build links in emails and MFA QR codes
APP_BASE_URL=https://app.billinx.ng

# ── MFA ───────────────────────────────────────────────────────────────────────
# Issuer name shown in authenticator apps (e.g. Google Authenticator)
MFA_ISSUER=Billinx

# ── API Keys ──────────────────────────────────────────────────────────────────
# Default expiry for newly created API keys (0 = no expiry)
API_KEY_DEFAULT_EXPIRY_DAYS=365

# ── Workers ───────────────────────────────────────────────────────────────────
# Concurrency for the individual invoice submission worker
WORKER_CONCURRENCY=10
# Concurrency for the bulk invoice submission worker (separate queue, lower priority)
BULK_WORKER_CONCURRENCY=5

# ── Interswitch / NRS ─────────────────────────────────────────────────────────
INTERSWITCH_SANDBOX_URL=https://qa.interswitchgroup.com
INTERSWITCH_PROD_URL=https://api.interswitchgroup.com
# NRS e-invoicing API base URL (confirm with NRS/Interswitch for production)
NRS_API_BASE_URL=https://api.interswitchgroup.com

# ── CAC (Corporate Affairs Commission) API ────────────────────────────────────
# Base URL for the CAC business search API
CAC_API_BASE_URL=
# Bearer token for the CAC API
CAC_API_KEY=

# ── AWS Secrets Manager ───────────────────────────────────────────────────────
# In production, these point to Secrets Manager secret names.
# The SecretsService fetches the actual secret values at runtime (5-min cache).
# In development, the service falls back to the values below.

# Secret name → SecretsService fetches this at runtime
JWT_PRIVATE_KEY_SECRET_ID=billinx/production/jwt-private-key
JWT_PUBLIC_KEY_SECRET_ID=billinx/production/jwt-public-key
MASTER_KEY_SECRET_ID=billinx/production/encryption-key
ADMIN_KEY_SECRET_ID=billinx/production/admin-api-key

# Dev-only fallback values (not used in production — Secrets Manager is the source of truth)
# Generate with: openssl genrsa -out private.key 2048 && openssl rsa -in private.key -pubout -out public.key
# Then paste the full PEM content (with newlines encoded as \n or use a multi-line string in a .env file)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# 64-char hex string for AES-256 encryption (dev only — Secrets Manager is used in prod)
MASTER_ENCRYPTION_KEY=

# ── JWT token expiry ─────────────────────────────────────────────────────────
# Access tokens (short-lived, recommended: 15m for production)
JWT_ACCESS_TOKEN_EXPIRY=15m
# Refresh tokens (longer-lived, recommended: 7d for production)
JWT_REFRESH_TOKEN_EXPIRY=7d
# MFA step-2 challenge tokens (must be short)
JWT_MFA_TOKEN_EXPIRY=5m

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Get DSN from sentry.io → Project Settings → Client Keys
# Leave empty to disable Sentry in development
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (dev: http://localhost:3001)
ALLOWED_ORIGINS=http://localhost:3001

# ── Payment providers ─────────────────────────────────────────────────────────
# Paystack — get keys from dashboard.paystack.com
# Use sk_test_* / pk_test_* for sandbox; sk_live_* / pk_live_* for production
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Flutterwave — get keys from dashboard.flutterwave.com
# Use FLWSECK_TEST_* for sandbox; FLWSECK_* for production
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
# Webhook hash — set a random string here and configure the same in Flutterwave dashboard
FLW_WEBHOOK_HASH=

# Public URL of the Billinx web app (used for payment callback URLs and payment links)
# In GitHub Codespaces: https://<CODESPACE_NAME>-3001.<domain>
BILLINX_URL=http://localhost:3001
