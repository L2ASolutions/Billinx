{
  "info": {
    "_postman_id": "b1ll1nx-c0mp1iance-api-v1",
    "name": "Billinx Compliance API",
    "description": "Nigeria FIRS/NRS e-invoicing compliance API. Covers auth, invoices, webhooks, users, and admin endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL of the Billinx API"
    },
    {
      "key": "api_key",
      "value": "",
      "type": "string",
      "description": "Tenant API key (blx_...)"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string",
      "description": "JWT access token from /v1/users/login"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string",
      "description": "Admin JWT from /v1/admin/auth/login"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints for obtaining and refreshing tokens.",
      "item": [
        {
          "name": "Get Access Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/auth/token",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@acmeng.ng\",\n  \"password\": \"SecurePass123!\",\n  \"tenantId\": \"ten_abc123\"\n}"
            },
            "description": "Exchange email/password for a JWT access token and refresh token."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<your_refresh_token>\"\n}"
            },
            "description": "Use a refresh token to get a new access token."
          }
        },
        {
          "name": "Revoke Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/auth/revoke",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "revoke"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<your_refresh_token>\"\n}"
            },
            "description": "Revoke a refresh token to invalidate a session."
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "description": "Create, validate, and retrieve FIRS-compliant e-invoices.",
      "item": [
        {
          "name": "Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" },
              { "key": "Idempotency-Key", "value": "inv-{{$randomUUID}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceTypeCode\": \"STANDARD\",\n  \"invoiceKind\": \"B2B\",\n  \"invoiceNumber\": \"INV-2026-001\",\n  \"issueDate\": \"2026-05-17\",\n  \"dueDate\": \"2026-06-17\",\n  \"currency\": \"NGN\",\n  \"seller\": {\n    \"tin\": \"12345678-0001\",\n    \"name\": \"Acme Engineering Ltd\",\n    \"address\": \"45 Adeola Odeku Street, Victoria Island, Lagos\",\n    \"phone\": \"+2348012345678\",\n    \"email\": \"accounts@acmeng.ng\"\n  },\n  \"buyer\": {\n    \"tin\": \"98765432-0001\",\n    \"name\": \"Lagos State Government\",\n    \"address\": \"The Secretariat, Alausa, Ikeja, Lagos\",\n    \"phone\": \"+2349087654321\",\n    \"email\": \"procurement@lasg.gov.ng\"\n  },\n  \"lineItems\": [\n    {\n      \"lineId\": \"1\",\n      \"description\": \"Civil Engineering Consultancy Services\",\n      \"quantity\": 1,\n      \"unitPrice\": 5000000.00,\n      \"lineExtensionAmount\": 5000000.00,\n      \"hsnCode\": \"998311\",\n      \"taxCategory\": \"STANDARD_VAT\",\n      \"taxRate\": 7.5\n    },\n    {\n      \"lineId\": \"2\",\n      \"description\": \"Topographic Survey\",\n      \"quantity\": 2,\n      \"unitPrice\": 750000.00,\n      \"lineExtensionAmount\": 1500000.00,\n      \"hsnCode\": \"998312\",\n      \"taxCategory\": \"STANDARD_VAT\",\n      \"taxRate\": 7.5\n    }\n  ],\n  \"taxTotal\": {\n    \"taxAmount\": 487500.00,\n    \"taxSubtotals\": [\n      {\n        \"taxCategory\": \"STANDARD_VAT\",\n        \"taxRate\": 7.5,\n        \"taxableAmount\": 6500000.00,\n        \"taxAmount\": 487500.00\n      }\n    ]\n  },\n  \"legalMonetaryTotal\": {\n    \"lineExtensionAmount\": 6500000.00,\n    \"taxExclusiveAmount\": 6500000.00,\n    \"taxInclusiveAmount\": 6987500.00,\n    \"payableAmount\": 6987500.00\n  }\n}"
            },
            "description": "Submit a new FIRS-compliant invoice. The API validates, generates an IRN, and queues it for FIRS submission."
          }
        },
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices?status=ACCEPTED&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices"],
              "query": [
                { "key": "status", "value": "ACCEPTED", "description": "Filter by invoice status" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "from", "value": "2026-01-01", "disabled": true },
                { "key": "to", "value": "2026-12-31", "disabled": true },
                { "key": "buyerTin", "value": "", "disabled": true }
              ]
            },
            "description": "List invoices for the authenticated tenant with optional filters."
          }
        },
        {
          "name": "Get Invoice",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id"],
              "variable": [
                { "key": "id", "value": "<invoice_id>" }
              ]
            },
            "description": "Retrieve a single invoice by ID. Add 'Accept: application/xml' header to get NRS-compliant XML."
          }
        },
        {
          "name": "Get Invoice Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id/status",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id", "status"],
              "variable": [
                { "key": "id", "value": "<invoice_id>" }
              ]
            },
            "description": "Get the full lifecycle status and state history of an invoice."
          }
        },
        {
          "name": "Validate Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/validate",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", "validate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceTypeCode\": \"STANDARD\",\n  \"invoiceKind\": \"B2B\",\n  \"invoiceNumber\": \"INV-2026-TEST\",\n  \"issueDate\": \"2026-05-17\",\n  \"currency\": \"NGN\",\n  \"seller\": {\n    \"tin\": \"12345678-0001\",\n    \"name\": \"Acme Engineering Ltd\",\n    \"address\": \"45 Adeola Odeku Street, Victoria Island, Lagos\"\n  },\n  \"buyer\": {\n    \"tin\": \"98765432-0001\",\n    \"name\": \"Lagos State Government\",\n    \"address\": \"The Secretariat, Alausa, Ikeja, Lagos\"\n  },\n  \"lineItems\": [\n    {\n      \"lineId\": \"1\",\n      \"description\": \"Test Service\",\n      \"quantity\": 1,\n      \"unitPrice\": 100000.00,\n      \"lineExtensionAmount\": 100000.00,\n      \"taxCategory\": \"STANDARD_VAT\",\n      \"taxRate\": 7.5\n    }\n  ],\n  \"taxTotal\": {\n    \"taxAmount\": 7500.00,\n    \"taxSubtotals\": [\n      {\n        \"taxCategory\": \"STANDARD_VAT\",\n        \"taxRate\": 7.5,\n        \"taxableAmount\": 100000.00,\n        \"taxAmount\": 7500.00\n      }\n    ]\n  },\n  \"legalMonetaryTotal\": {\n    \"lineExtensionAmount\": 100000.00,\n    \"taxExclusiveAmount\": 100000.00,\n    \"taxInclusiveAmount\": 107500.00,\n    \"payableAmount\": 107500.00\n  }\n}"
            },
            "description": "Validate an invoice against FIRS rules without submitting it. Returns validation errors if any."
          }
        },
        {
          "name": "Export Invoices CSV",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/export/csv?startDate=2026-01-01&endDate=2026-05-31",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", "export", "csv"],
              "query": [
                { "key": "startDate", "value": "2026-01-01" },
                { "key": "endDate", "value": "2026-05-31" }
              ]
            },
            "description": "Export invoices as CSV for compliance reporting."
          }
        },
        {
          "name": "Export Monthly Report",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/export/monthly?year=2026&month=5",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", "export", "monthly"],
              "query": [
                { "key": "year", "value": "2026" },
                { "key": "month", "value": "5" }
              ]
            },
            "description": "Get a monthly summary report of invoice activity."
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "description": "Manage webhook subscriptions for real-time invoice event notifications.",
      "item": [
        {
          "name": "Create Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/webhooks",
              "host": ["{{base_url}}"],
              "path": ["v1", "webhooks"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://yourapp.ng/webhooks/billinx\",\n  \"events\": [\"invoice.accepted\", \"invoice.rejected\", \"invoice.cancelled\"],\n  \"description\": \"Production webhook for invoice state changes\"\n}"
            },
            "description": "Subscribe to invoice events. Billinx will send HMAC-signed POST requests to your URL."
          }
        },
        {
          "name": "List Webhooks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/webhooks",
              "host": ["{{base_url}}"],
              "path": ["v1", "webhooks"]
            },
            "description": "List all webhook subscriptions for your tenant."
          }
        },
        {
          "name": "Delete Webhook",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/webhooks/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "webhooks", ":id"],
              "variable": [
                { "key": "id", "value": "<webhook_id>" }
              ]
            },
            "description": "Delete a webhook subscription."
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "User registration, login, and invitation management.",
      "item": [
        {
          "name": "Register (Create Tenant + Owner)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/users/register",
              "host": ["{{base_url}}"],
              "path": ["v1", "users", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Chidi\",\n  \"lastName\": \"Okonkwo\",\n  \"email\": \"chidi@acmeng.ng\",\n  \"password\": \"SecurePass123!\",\n  \"tenantName\": \"Acme Engineering Ltd\",\n  \"tenantEmail\": \"hello@acmeng.ng\",\n  \"tenantPhone\": \"+2348012345678\",\n  \"tin\": \"12345678-0001\"\n}"
            },
            "description": "Register a new tenant and create the OWNER user account."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/users/login",
              "host": ["{{base_url}}"],
              "path": ["v1", "users", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"ten_abc123\",\n  \"email\": \"chidi@acmeng.ng\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "description": "Authenticate with email and password. Returns access and refresh tokens."
          }
        },
        {
          "name": "Invite User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/users/invite",
              "host": ["{{base_url}}"],
              "path": ["v1", "users", "invite"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"amara@acmeng.ng\",\n  \"firstName\": \"Amara\",\n  \"lastName\": \"Eze\",\n  \"role\": \"ACCOUNTANT\"\n}"
            },
            "description": "Invite a team member to join your tenant. They will receive a 7-day invitation email."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "description": "L2A Solutions staff admin endpoints. Requires X-Admin-Key or admin JWT.",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/auth/login",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@l2asolutions.com\",\n  \"password\": \"AdminSecure123!\"\n}"
            },
            "description": "Authenticate as an L2A Solutions admin user. Store the returned token as {{admin_token}}."
          }
        },
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/tenants?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "tenants"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "List all registered tenants on the platform."
          }
        },
        {
          "name": "Platform Metrics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/metrics",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "metrics"]
            },
            "description": "Get platform-wide metrics: invoices submitted today/week/month, acceptance rates, active tenants."
          }
        },
        {
          "name": "Queue Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/queue/status",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "queue", "status"]
            },
            "description": "Get submission queue depth and job counts."
          }
        },
        {
          "name": "Retry Failed Jobs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/queue/retry-failed",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "queue", "retry-failed"]
            },
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "description": "Re-queue all failed submission jobs for retry."
          }
        },
        {
          "name": "Retention Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/retention/stats",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "retention", "stats"]
            },
            "description": "Get data retention statistics (archived invoices, activity events)."
          }
        },
        {
          "name": "Run Retention",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/retention/run",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "retention", "run"]
            },
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "description": "Manually trigger the data retention archiving job."
          }
        },
        {
          "name": "Verify Audit Chain",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/audit/verify",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "audit", "verify"]
            },
            "description": "Verify the integrity of the hash-chained immutable audit log."
          }
        },
        {
          "name": "Platform CSV Export",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/export/platform-csv?startDate=2026-01-01&endDate=2026-05-31",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "export", "platform-csv"],
              "query": [
                { "key": "startDate", "value": "2026-01-01" },
                { "key": "endDate", "value": "2026-05-31" }
              ]
            },
            "description": "Export all invoices across all tenants as CSV (FIRS audit use)."
          }
        }
      ]
    },
    {
      "name": "Products",
      "description": "Product catalog for pre-loading line item data into invoices.",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/products",
              "host": ["{{base_url}}"],
              "path": ["v1", "products"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Civil Engineering Consultancy\",\n  \"description\": \"Professional civil engineering design and consultancy services\",\n  \"hsnCode\": \"998311\",\n  \"productCategory\": \"Professional Services\",\n  \"unitPrice\": 5000000.00,\n  \"currency\": \"NGN\",\n  \"taxCategoryId\": \"STANDARD_VAT\"\n}"
            },
            "description": "Create a product in your catalog for reuse across invoices."
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/products?isActive=true",
              "host": ["{{base_url}}"],
              "path": ["v1", "products"],
              "query": [
                { "key": "isActive", "value": "true" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "category", "value": "", "disabled": true }
              ]
            },
            "description": "List products in your catalog."
          }
        },
        {
          "name": "Get Product as Line Item",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/products/:id/as-line-item",
              "host": ["{{base_url}}"],
              "path": ["v1", "products", ":id", "as-line-item"],
              "variable": [
                { "key": "id", "value": "<product_id>" }
              ]
            },
            "description": "Get a product formatted as an invoice line item ready to paste into a Create Invoice request."
          }
        }
      ]
    },
    {
      "name": "Health",
      "description": "Health and readiness checks.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns database, Redis, and queue health with latency metrics."
          }
        },
        {
          "name": "OpenAPI Spec (JSON)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/docs-json",
              "host": ["{{base_url}}"],
              "path": ["api", "docs-json"]
            },
            "description": "Download the full OpenAPI 3.0 specification. In production this requires a valid Bearer JWT (same access token as dashboard auth)."
          }
        }
      ]
    }
  ]
}
