generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                      String            @id @default(uuid())
  name                    String
  tin                     String            @unique
  registeredAddress       Json
  appAdapterKey           String            @default("mock")
  encryptedCredential     Bytes?
  credentialIv            Bytes?
  environment             TenantEnvironment @default(SANDBOX)
  rateLimitTier           RateLimitTier     @default(STANDARD)
  batchEnabled            Boolean           @default(false)
  batchSize               Int               @default(100)
  isActive                Boolean           @default(true)
  interswitchClientId     String?
  interswitchClientSecret Bytes?
  interswitchSecretIv     Bytes?
  interswitchServiceId    String?
  interswitchBusinessId   String?
  nrsApiKey               Bytes?
  nrsApiKeyIv             Bytes?
  nrsApiSecret            Bytes?
  nrsApiSecretIv          Bytes?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  apiKeys              ApiKey[]
  refreshTokens        RefreshToken[]
  webhookSubscriptions WebhookSubscription[]
  auditLogs            AuditLog[]
  invoices             Invoice[]
  activityEvents ActivityEvent[]
systemErrors   SystemError[]
users         User[]

  @@map("tenants")
}

model ApiKey {
  id          String            @id @default(uuid())
  tenantId    String
  keyHash     String            @unique
  keyPrefix   String
  environment TenantEnvironment
  name        String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isRevoked   Boolean           @default(false)
  createdAt   DateTime          @default(now())

  tenant      Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([keyPrefix])
  @@map("api_keys")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("refresh_tokens")
}

model AdminKey {
  id         String   @id @default(uuid())
  keyHash    String   @unique
  keyPrefix  String
  name       String
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([keyPrefix])
  @@map("admin_keys")
}

model IdempotencyRecord {
  id              String   @id @default(uuid())
  tenantId        String
  idempotencyKey  String
  requestHash     String
  responseBody    Json
  responseStatus  Int
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@unique([tenantId, idempotencyKey])
  @@index([expiresAt])
  @@map("idempotency_records")
}

  model Invoice {
  id                    String            @id @default(uuid())
  tenantId              String
  userId                String?
  environment           TenantEnvironment
  schemaVersion         String            @default("2.0")
  invoiceTypeCode       InvoiceTypeCode
  invoiceKind           InvoiceKind?
  platformIrn           String            @unique
  firsConfirmedIrn      String?
  sourceReference       String?
  buyerReference        String?
  orderReference        String?
  accountingCost        String?
  sellerTin             String
  sellerName            String
  buyerTin              String?
  buyerName             String
  issueDate             DateTime
  issueTime             String?
  dueDate               DateTime?
  taxPointDate          DateTime?
  actualDeliveryDate    DateTime?
  paymentStatus         String?
  currency              String            @default("NGN")
  taxCurrencyCode       String?
  exchangeRate          Decimal?
  exchangeRateSource    String?
  subtotal              Decimal
  vatAmount             Decimal
  totalAmount           Decimal
  lineItems             Json
  taxTotal              Json
  legalMonetaryTotal    Json
  paymentMeans          Json?
  allowanceCharges      Json?
  billingReference      Json?
  documentReferences    Json?
  invoiceDeliveryPeriod Json?
  paymentTermsNote      String?
  note                  String?
  metadata              Json?
  originalIrn           String?
  qrCodeBase64          String?
  status                InvoiceStatus     @default(DRAFT)
  submittedAt           DateTime?
  acceptedAt            DateTime?
  rejectedAt            DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  stateHistory          InvoiceStateHistory[]
  submissionAttempts    SubmissionAttempt[]

  @@index([tenantId, status])
  @@index([tenantId, environment])
  @@index([sellerTin])
  @@index([platformIrn])
  @@index([issueDate])
  @@index([userId])
  @@map("invoices")
}

model InvoiceStateHistory {
  id         String        @id @default(uuid())
  invoiceId  String
  tenantId   String
  fromStatus InvoiceStatus?
  toStatus   InvoiceStatus
  actor      String
  reason     String?
  metadata   Json?
  createdAt  DateTime      @default(now())

  invoice    Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([tenantId, createdAt])
  @@map("invoice_state_history")
}

model SubmissionAttempt {
  id              String   @id @default(uuid())
  invoiceId       String
  tenantId        String
  adapterKey      String
  attemptNumber   Int
  requestPayload  Json
  responsePayload Json?
  responseCode    String?
  errorCode       String?
  errorMessage    String?
  durationMs      Int?
  succeededAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime @default(now())

  invoice         Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("submission_attempts")
}

model WebhookSubscription {
  id          String    @id @default(uuid())
  tenantId    String
  url         String
  signingKey  Bytes
  signingIv   Bytes
  eventTypes  String[]
  isActive    Boolean   @default(true)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  deliveries  WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id               String                @id @default(uuid())
  subscriptionId   String
  tenantId         String
  eventType        String
  eventId          String
  payload          Json
  attemptCount     Int                   @default(0)
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  status           WebhookDeliveryStatus @default(PENDING)
  lastResponseCode Int?
  lastResponseBody String?
  deliveredAt      DateTime?
  createdAt        DateTime              @default(now())

  subscription     WebhookSubscription   @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId, status])
  @@index([nextRetryAt])
  @@map("webhook_deliveries")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  eventType  String
  entityType String
  entityId   String
  actor      String
  ipAddress  String?
  userAgent  String?
  payload    Json
  createdAt  DateTime @default(now())

  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum TenantEnvironment {
  SANDBOX
  PRODUCTION
}

enum RateLimitTier {
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum InvoiceTypeCode {
  STANDARD
  CREDIT_NOTE
  DEBIT_NOTE
  PROFORMA
}

enum InvoiceKind {
  B2B
  B2C
  B2G
}

enum InvoiceStatus {
  DRAFT
  VALIDATING
  VALIDATION_FAILED
  QUEUED
  SUBMITTING
  SUBMITTED
  ACCEPTED
  REJECTED
  SUBMISSION_FAILED
  DEAD_LETTERED
  CANCELLATION_REQUESTED
  CANCELLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTERED
}
// ── ACTIVITY EVENTS ───────────────────────────────────────────────────────────
model ActivityEvent {
  id          String            @id @default(uuid())
  tenantId    String?
  eventType   ActivityEventType
  actor       String
  actorEmail  String?
  ipAddress   String?
  userAgent   String?
  entityType  String?
  entityId    String?
  payload     Json
  occurredAt  DateTime          @default(now())

  tenant      Tenant?           @relation(fields: [tenantId], references: [id])

  @@index([tenantId, occurredAt])
  @@index([tenantId, eventType])
  @@index([entityId])
  @@map("activity_events")
}

// ── SYSTEM ERRORS ─────────────────────────────────────────────────────────────
model SystemError {
  id             String        @id @default(uuid())
  tenantId       String?
  errorCode      String
  errorMessage   String
  stackTrace     String?
  endpoint       String?
  method         String?
  actor          String?
  requestId      String?
  severity       ErrorSeverity @default(LOW)
  isResolved     Boolean       @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?
  occurredAt     DateTime      @default(now())

  tenant         Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([isResolved, severity])
  @@index([tenantId, occurredAt])
  @@map("system_errors")
}

// ── USERS ─────────────────────────────────────────────────────────────────────
model User {
  id                   String    @id @default(uuid())
  tenantId             String
  email                String
  passwordHash         String
  firstName            String
  lastName             String
  isActive             Boolean   @default(true)
  isVerified           Boolean   @default(false)
  mfaEnabled           Boolean   @default(false)
  mfaSecret            Bytes?
  mfaSecretIv          Bytes?
  mfaBackupCodes       Json?
  lastLoginAt          DateTime?
  isErased             Boolean   @default(false)
  erasureRequestedAt   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant               Tenant        @relation(fields: [tenantId], references: [id])
  roles                UserRole[]
  invitations          UserInvitation[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ── USER ROLES ────────────────────────────────────────────────────────────────
model UserRole {
  id        String       @id @default(uuid())
  userId    String
  tenantId  String
  role      UserRoleType
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@index([tenantId])
  @@map("user_roles")
}

// ── USER INVITATIONS ──────────────────────────────────────────────────────────
model UserInvitation {
  id          String       @id @default(uuid())
  tenantId    String
  email       String
  role        UserRoleType
  token       String       @unique
  invitedBy   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  isRevoked   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  invitedByUser User?      @relation(fields: [invitedBy], references: [id])

  @@index([tenantId])
  @@index([token])
  @@map("user_invitations")
}

// ── PASSWORD RESET TOKENS ─────────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@map("password_reset_tokens")
}

// ── ACCESS REQUESTS ───────────────────────────────────────────────────────────
model AccessRequest {
  id              String              @id @default(uuid())
  companyName     String
  tin             String
  contactName     String
  email           String
  phone           String?
  estimatedVolume String?
  useCase         String?
  status          AccessRequestStatus @default(PENDING)
  cacRcNumber     String?
  kybScore        KybRiskScore        @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  kybVerification KybVerification?

  @@index([status])
  @@index([email])
  @@map("access_requests")
}

// ── KYB VERIFICATION ──────────────────────────────────────────────────────────
model KybVerification {
  id                  String       @id @default(uuid())
  accessRequestId     String       @unique
  tenantId            String?

  tin                 String
  tinUserConfirmed    Boolean      @default(false)
  tinConfirmedAt      DateTime?
  tinConfirmedIp      String?
  tinProofNote        String?

  cacRcNumber         String?
  cacVerified         Boolean      @default(false)
  cacVerifiedAt       DateTime?
  cacCompanyName      String?
  cacStatus           String?
  cacRegistrationDate String?
  cacDirectors        Json?
  cacRawResponse      Json?
  cacErrorMessage     String?

  nameMatchScore      Float?
  nameMatchResult     String?

  riskScore           KybRiskScore @default(PENDING)
  riskReasons         Json?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  accessRequest       AccessRequest @relation(fields: [accessRequestId], references: [id])

  @@map("kyb_verifications")
}
// ── ADMIN USERS (L2A Solutions staff) ─────────────────────────────────────────
model AdminUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          AdminRole @default(STAFF)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  STAFF
}
enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KybRiskScore {
  PENDING
  GREEN
  AMBER
  RED
}

enum ConsentType {
  TERMS_AND_PRIVACY
  NDPR_DATA_PROCESSING
  BUSINESS_AUTHORISATION
}

enum ErasureRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── CONSENT RECORDS ───────────────────────────────────────────────────────────
model ConsentRecord {
  id             String      @id @default(uuid())
  userId         String?
  tenantId       String?
  email          String
  consentType    ConsentType
  consentVersion String      @default("1.0")
  ipAddress      String?
  userAgent      String?
  consentedAt    DateTime    @default(now())
  revokedAt      DateTime?
  isRevoked      Boolean     @default(false)
  metadata       Json?

  @@index([userId])
  @@index([tenantId])
  @@index([email])
  @@index([consentType])
  @@map("consent_records")
}

// ── ERASURE REQUESTS ──────────────────────────────────────────────────────────
model ErasureRequest {
  id          String               @id @default(uuid())
  userId      String
  tenantId    String
  email       String
  status      ErasureRequestStatus @default(PENDING)
  requestedAt DateTime             @default(now())
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  erasedAt    DateTime?

  @@index([userId])
  @@index([status])
  @@map("erasure_requests")
}
enum ActivityEventType {
  USER_LOGIN
  USER_LOGOUT
  USER_LOGIN_FAILED
  API_KEY_CREATED
  API_KEY_REVOKED
  INVOICE_CREATED
  INVOICE_VALIDATED
  INVOICE_SUBMITTED
  INVOICE_ACCEPTED
  INVOICE_REJECTED
  INVOICE_CANCELLED
  INVOICE_VIEWED
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_DEACTIVATED
  WEBHOOK_DELIVERED
  WEBHOOK_FAILED
  EXPORT_GENERATED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  USER_CREATED
  USER_DEACTIVATED
  PASSWORD_RESET
  SYSTEM_ERROR
}

enum ErrorSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserRoleType {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
  API_MANAGER
}