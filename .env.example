# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://billinx:billinx_secret@localhost:5432/billinx

# Postgres service vars (used by docker-compose; DATABASE_URL is built from these)
POSTGRES_DB=billinx
POSTGRES_USER=billinx
POSTGRES_PASSWORD=billinx_secret
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank to disable Redis auth in development
REDIS_PASSWORD=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change both secrets before deploying to production
JWT_SECRET=billinx-dev-secret-change-in-production
ADMIN_JWT_SECRET=billinx-admin-secret-change-in-production

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES (email delivery) — can use a different region from the main account
AWS_SES_REGION=us-east-1

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_FROM=Billinx <noreply@billinx.ng>
# Base URL used to build links in emails and MFA QR codes
APP_BASE_URL=https://app.billinx.ng

# ── MFA ───────────────────────────────────────────────────────────────────────
# Issuer name shown in authenticator apps (e.g. Google Authenticator)
MFA_ISSUER=Billinx

# ── Interswitch ───────────────────────────────────────────────────────────────
INTERSWITCH_SANDBOX_URL=https://qa.interswitchgroup.com
INTERSWITCH_PROD_URL=https://api.interswitchgroup.com

# ── AWS Secrets Manager ───────────────────────────────────────────────────────
# Secret IDs for keys stored in Secrets Manager (used in production)
# In development these fall back to JWT_SECRET / in-memory generated keys
JWT_PRIVATE_KEY_SECRET_ID=billinx/jwt/private-key
JWT_PUBLIC_KEY_SECRET_ID=billinx/jwt/public-key
MASTER_KEY_SECRET_ID=billinx/encryption/master-key
ADMIN_KEY_SECRET_ID=billinx/admin/key-hash
