generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                      String            @id @default(uuid())
  name                    String
  tin                     String            @unique
  registeredAddress       Json
  appAdapterKey           String            @default("mock")
  encryptedCredential     Bytes?
  credentialIv            Bytes?
  environment             TenantEnvironment @default(SANDBOX)
  rateLimitTier           RateLimitTier     @default(STANDARD)
  batchEnabled            Boolean           @default(false)
  batchSize               Int               @default(100)
  isActive                Boolean           @default(true)
  interswitchClientId     String?
  interswitchClientSecret Bytes?
  interswitchSecretIv     Bytes?
  interswitchServiceId    String?
  interswitchBusinessId   String?
  telephone               String?
  phone                   String?
  industry                String?
  businessDescription     String?
  bankName                String?
  bankAccount             String?
  bankAccountName         String?
  taxRepresentative       Json?
  nrsApiKey               Bytes?
  nrsApiKeyIv             Bytes?
  nrsApiSecret            Bytes?
  nrsApiSecretIv          Bytes?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  apiKeys              ApiKey[]
  refreshTokens        RefreshToken[]
  webhookSubscriptions WebhookSubscription[]
  auditLogs            AuditLog[]
  invoices             Invoice[]
  activityEvents ActivityEvent[]
systemErrors   SystemError[]
users         User[]
  productCatalog   ProductCatalog[]
  bulkBatches      BulkBatch[]
  reminderRules    ReminderRule[]
  reminderLogs     ReminderLog[]
  incomingInvoices IncomingInvoice[]
  vatEntries       VatEntry[]
  vatPeriodSummaries VatPeriodSummary[]
  clients            Client[]

  @@map("tenants")
}

model ApiKey {
  id           String            @id @default(uuid())
  tenantId     String
  keyHash      String            @unique
  keyPrefix    String
  environment  TenantEnvironment
  name         String
  lastUsedAt   DateTime?
  lastUsedIp   String?
  requestCount Int               @default(0)
  expiresAt    DateTime?
  isRevoked    Boolean           @default(false)
  createdAt    DateTime          @default(now())

  tenant       Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([keyPrefix])
  @@index([expiresAt])
  @@map("api_keys")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("refresh_tokens")
}

model AdminKey {
  id         String   @id @default(uuid())
  keyHash    String   @unique
  keyPrefix  String
  name       String
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([keyPrefix])
  @@map("admin_keys")
}

model IdempotencyRecord {
  id              String   @id @default(uuid())
  tenantId        String
  idempotencyKey  String
  requestHash     String
  responseBody    Json
  responseStatus  Int
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@unique([tenantId, idempotencyKey])
  @@index([expiresAt])
  @@map("idempotency_records")
}

  model Invoice {
  id                    String            @id @default(uuid())
  tenantId              String
  userId                String?
  environment           TenantEnvironment
  schemaVersion         String            @default("2.0")
  invoiceTypeCode       InvoiceTypeCode
  invoiceKind           InvoiceKind?
  platformIrn           String            @unique
  firsConfirmedIrn      String?
  sourceReference       String?
  buyerReference        String?
  orderReference        String?
  accountingCost        String?
  sellerTin             String
  sellerName            String
  buyerTin              String?
  buyerName             String
  issueDate             DateTime
  issueTime             String?
  dueDate               DateTime?
  taxPointDate          DateTime?
  actualDeliveryDate    DateTime?
  paymentStatus         String?
  currency              String            @default("NGN")
  taxCurrencyCode       String?
  exchangeRate          Decimal?
  exchangeRateSource    String?
  subtotal              Decimal
  vatAmount             Decimal
  totalAmount           Decimal
  lineItems             Json
  taxTotal              Json
  legalMonetaryTotal    Json
  paymentMeans          Json?
  allowanceCharges      Json?
  billingReference      Json?
  documentReferences    Json?
  invoiceDeliveryPeriod Json?
  deliveryPeriodStart   DateTime?
  deliveryPeriodEnd     DateTime?
  paymentTermsNote      String?
  note                  String?
  metadata              Json?
  originalIrn           String?
  qrCodeBase64          String?
  paymentLink           String?
  buyerEmail            String?
  status                InvoiceStatus     @default(DRAFT)
  submittedAt           DateTime?
  acceptedAt            DateTime?
  rejectedAt            DateTime?
  cancelledAt           DateTime?
  archivedAt            DateTime?
  isArchived            Boolean           @default(false)
  amountPaid            Decimal           @default(0)
  paymentDueDate        DateTime?
  isOverdue             Boolean           @default(false)
  overdueAt             DateTime?
  reminderCount         Int               @default(0)
  lastReminderAt        DateTime?
  whtApplicable         Boolean           @default(false)
  whtRate               Decimal?
  whtAmount             Decimal?
  expectedCash          Decimal?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  stateHistory          InvoiceStateHistory[]
  submissionAttempts    SubmissionAttempt[]
  paymentRecords        PaymentRecord[]
  reminderLogs          ReminderLog[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, paymentStatus])
  @@index([tenantId, environment])
  @@index([tenantId, sourceReference])
  @@index([tenantId, isOverdue])
  @@index([sellerTin])
  @@index([platformIrn])
  @@index([issueDate])
  @@index([userId])
  @@index([paymentDueDate])
  @@map("invoices")
}

model InvoiceStateHistory {
  id         String        @id @default(uuid())
  invoiceId  String
  tenantId   String
  fromStatus InvoiceStatus?
  toStatus   InvoiceStatus
  actor      String
  reason     String?
  metadata   Json?
  createdAt  DateTime      @default(now())

  invoice    Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([tenantId, createdAt])
  @@map("invoice_state_history")
}

model SubmissionAttempt {
  id              String   @id @default(uuid())
  invoiceId       String
  tenantId        String
  adapterKey      String
  attemptNumber   Int
  requestPayload  Json
  responsePayload Json?
  responseCode    String?
  errorCode       String?
  errorMessage    String?
  durationMs      Int?
  succeededAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime @default(now())

  invoice         Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("submission_attempts")
}

model WebhookSubscription {
  id          String    @id @default(uuid())
  tenantId    String
  url         String
  signingKey  Bytes
  signingIv   Bytes
  eventTypes  String[]
  isActive    Boolean   @default(true)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  deliveries  WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id               String                @id @default(uuid())
  subscriptionId   String
  tenantId         String
  eventType        String
  eventId          String
  payload          Json
  attemptCount     Int                   @default(0)
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  status           WebhookDeliveryStatus @default(PENDING)
  lastResponseCode Int?
  lastResponseBody String?
  deliveredAt      DateTime?
  createdAt        DateTime              @default(now())

  subscription     WebhookSubscription   @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId, status])
  @@index([nextRetryAt])
  @@map("webhook_deliveries")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  eventType  String
  entityType String
  entityId   String
  actor      String
  ipAddress  String?
  userAgent  String?
  payload    Json
  createdAt  DateTime @default(now())

  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum TenantEnvironment {
  SANDBOX
  PRODUCTION
}

enum RateLimitTier {
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum InvoiceTypeCode {
  STANDARD
  CREDIT_NOTE
  DEBIT_NOTE
  PROFORMA
}

enum InvoiceKind {
  B2B
  B2C
  B2G
}

enum InvoiceStatus {
  DRAFT
  VALIDATING
  VALIDATION_FAILED
  QUEUED
  SUBMITTING
  SUBMITTED
  ACCEPTED
  REJECTED
  SUBMISSION_FAILED
  DEAD_LETTERED
  CANCELLATION_REQUESTED
  CANCELLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTERED
}
// ── ACTIVITY EVENTS ───────────────────────────────────────────────────────────
model ActivityEvent {
  id          String            @id @default(uuid())
  tenantId    String?
  eventType   ActivityEventType
  actor       String
  actorEmail  String?
  ipAddress   String?
  userAgent   String?
  entityType  String?
  entityId    String?
  payload      Json
  occurredAt   DateTime @default(now())
  isArchived   Boolean  @default(false)
  entryHash    String?
  previousHash String?

  tenant      Tenant?           @relation(fields: [tenantId], references: [id])

  @@index([tenantId, occurredAt])
  @@index([tenantId, eventType])
  @@index([entityId])
  @@map("activity_events")
}

// ── PRODUCT CATALOG ───────────────────────────────────────────────────────────
model ProductCatalog {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  hsnCode         String?
  productCategory String?
  unitPrice       Decimal
  currency        String   @default("NGN")
  taxCategoryId   String   @default("STANDARD_VAT")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("product_catalog")
}

// ── SYSTEM ERRORS ─────────────────────────────────────────────────────────────
model SystemError {
  id             String        @id @default(uuid())
  tenantId       String?
  errorCode      String
  errorMessage   String
  stackTrace     String?
  endpoint       String?
  method         String?
  actor          String?
  requestId      String?
  severity       ErrorSeverity @default(LOW)
  isResolved     Boolean       @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?
  occurredAt     DateTime      @default(now())

  tenant         Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([isResolved, severity])
  @@index([tenantId, occurredAt])
  @@map("system_errors")
}

// ── USERS ─────────────────────────────────────────────────────────────────────
model User {
  id                   String    @id @default(uuid())
  tenantId             String
  email                String
  passwordHash         String
  firstName            String
  lastName             String
  isActive             Boolean   @default(true)
  isVerified           Boolean   @default(false)
  mfaEnabled           Boolean   @default(false)
  mfaSecret            Bytes?
  mfaSecretIv          Bytes?
  mfaBackupCodes       Json?
  lastLoginAt          DateTime?
  isErased             Boolean   @default(false)
  erasureRequestedAt   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant               Tenant        @relation(fields: [tenantId], references: [id])
  roles                UserRole[]
  invitations          UserInvitation[]
  preference           UserPreference?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ── USER PREFERENCES ──────────────────────────────────────────────────────────
model UserPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  tenantId    String
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@map("user_preferences")
}

// ── USER ROLES ────────────────────────────────────────────────────────────────
model UserRole {
  id        String       @id @default(uuid())
  userId    String
  tenantId  String
  role      UserRoleType
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@index([tenantId])
  @@map("user_roles")
}

// ── USER INVITATIONS ──────────────────────────────────────────────────────────
model UserInvitation {
  id          String       @id @default(uuid())
  tenantId    String
  email       String
  role        UserRoleType
  token       String       @unique
  invitedBy   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  isRevoked   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  invitedByUser User?      @relation(fields: [invitedBy], references: [id])

  @@index([tenantId])
  @@index([token])
  @@map("user_invitations")
}

// ── PASSWORD RESET TOKENS ─────────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@map("password_reset_tokens")
}

// ── ACCESS REQUESTS ───────────────────────────────────────────────────────────
model AccessRequest {
  id              String              @id @default(uuid())
  companyName     String
  tin             String
  contactName     String
  email           String
  phone           String?
  estimatedVolume String?
  useCase         String?
  status          AccessRequestStatus @default(PENDING)
  cacRcNumber     String?
  kybScore        KybRiskScore        @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  kybVerification KybVerification?

  @@index([status])
  @@index([email])
  @@map("access_requests")
}

// ── KYB VERIFICATION ──────────────────────────────────────────────────────────
model KybVerification {
  id                  String       @id @default(uuid())
  accessRequestId     String       @unique
  tenantId            String?

  tin                 String
  tinUserConfirmed    Boolean      @default(false)
  tinConfirmedAt      DateTime?
  tinConfirmedIp      String?
  tinProofNote        String?

  cacRcNumber         String?
  cacVerified         Boolean      @default(false)
  cacVerifiedAt       DateTime?
  cacCompanyName      String?
  cacStatus           String?
  cacRegistrationDate String?
  cacDirectors        Json?
  cacRawResponse      Json?
  cacErrorMessage     String?

  nameMatchScore      Float?
  nameMatchResult     String?

  riskScore           KybRiskScore @default(PENDING)
  riskReasons         Json?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  accessRequest       AccessRequest @relation(fields: [accessRequestId], references: [id])

  @@map("kyb_verifications")
}
// ── ADMIN USERS (L2A Solutions staff) ─────────────────────────────────────────
model AdminUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          AdminRole @default(STAFF)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  STAFF
}
enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KybRiskScore {
  PENDING
  GREEN
  AMBER
  RED
}

enum ConsentType {
  TERMS_AND_PRIVACY
  NDPR_DATA_PROCESSING
  BUSINESS_AUTHORISATION
}

enum ErasureRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── CONSENT RECORDS ───────────────────────────────────────────────────────────
model ConsentRecord {
  id             String      @id @default(uuid())
  userId         String?
  tenantId       String?
  email          String
  consentType    ConsentType
  consentVersion String      @default("1.0")
  ipAddress      String?
  userAgent      String?
  consentedAt    DateTime    @default(now())
  revokedAt      DateTime?
  isRevoked      Boolean     @default(false)
  metadata       Json?

  @@index([userId])
  @@index([tenantId])
  @@index([email])
  @@index([consentType])
  @@map("consent_records")
}

// ── ERASURE REQUESTS ──────────────────────────────────────────────────────────
model ErasureRequest {
  id          String               @id @default(uuid())
  userId      String
  tenantId    String
  email       String
  status      ErasureRequestStatus @default(PENDING)
  requestedAt DateTime             @default(now())
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  erasedAt    DateTime?

  @@index([userId])
  @@index([status])
  @@map("erasure_requests")
}
enum ActivityEventType {
  USER_LOGIN
  USER_LOGOUT
  USER_LOGIN_FAILED
  API_KEY_CREATED
  API_KEY_REVOKED
  INVOICE_CREATED
  INVOICE_VALIDATED
  INVOICE_SUBMITTED
  INVOICE_ACCEPTED
  INVOICE_REJECTED
  INVOICE_CANCELLED
  INVOICE_VIEWED
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_DEACTIVATED
  WEBHOOK_DELIVERED
  WEBHOOK_FAILED
  EXPORT_GENERATED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  USER_CREATED
  USER_DEACTIVATED
  PASSWORD_RESET
  SYSTEM_ERROR
  PAYMENT_RECORDED
  INVOICE_OVERDUE
  REMINDER_SENT
  INCOMING_INVOICE_RECEIVED
  INCOMING_INVOICE_VALIDATED
  INCOMING_INVOICE_APPROVED
  VAT_ENTRY_CREATED
  VAT_ENTRY_RECONCILED
  VAT_PERIOD_CLOSED
  INCOMING_INVOICE_REJECTED
  INCOMING_INVOICE_PAID
  CLIENT_CREATED
  CLIENT_UPDATED
}

enum ReminderTriggerType {
  DAYS_BEFORE_DUE
  ON_DUE_DATE
  DAYS_AFTER_DUE
}

enum ErrorSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ── BULK BATCHES ──────────────────────────────────────────────────────────────
model BulkBatch {
  id           String            @id @default(uuid())
  tenantId     String
  environment  TenantEnvironment
  actor        String
  source       BulkBatchSource   @default(JSON)
  fileName     String?
  total        Int
  queued       Int               @default(0)
  invalidCount Int               @default(0)
  processing   Int               @default(0)
  accepted     Int               @default(0)
  rejected     Int               @default(0)
  failed       Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("bulk_batches")
}

enum BulkBatchSource {
  JSON
  CSV
}

// ── PAYMENT RECORDS ───────────────────────────────────────────────────────────
model PaymentRecord {
  id               String   @id @default(uuid())
  invoiceId        String
  tenantId         String
  amount           Decimal
  currency         String   @default("NGN")
  paymentReference String
  provider         String
  paidAt           DateTime
  confirmedAt      DateTime?
  confirmedBy      String?
  notes            String?
  whtDeducted      Decimal?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invoice          Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([tenantId])
  @@index([tenantId, paidAt])
  @@map("payment_records")
}

enum UserRoleType {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
  API_MANAGER
}

// ── REMINDER RULES ────────────────────────────────────────────────────────────
model ReminderRule {
  id              String              @id @default(uuid())
  tenantId        String
  name            String
  triggerType     ReminderTriggerType
  triggerDays     Int
  isActive        Boolean             @default(true)
  reminderMessage String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  reminderLogs    ReminderLog[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("reminder_rules")
}

// ── REMINDER LOGS ─────────────────────────────────────────────────────────────
model ReminderLog {
  id               String   @id @default(uuid())
  invoiceId        String
  tenantId         String
  ruleId           String
  sentAt           DateTime @default(now())
  emailSentTo      String
  webhookDelivered Boolean  @default(false)

  invoice          Invoice      @relation(fields: [invoiceId], references: [id])
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  rule             ReminderRule @relation(fields: [ruleId], references: [id])

  @@unique([invoiceId, ruleId])
  @@index([tenantId])
  @@index([invoiceId])
  @@map("reminder_logs")
}

// ── INCOMING INVOICES ─────────────────────────────────────────────────────────
enum IncomingInvoiceStatus {
  RECEIVED
  VALIDATED
  REJECTED
  APPROVED
  PAID
}

model IncomingInvoice {
  id              String                 @id @default(uuid())
  tenantId        String
  supplierName    String
  supplierTin     String
  invoiceNumber   String
  invoiceAmount   Decimal
  vatAmount       Decimal
  currency        String                 @default("NGN")
  invoiceDate     DateTime
  dueDate         DateTime?
  status          IncomingInvoiceStatus  @default(RECEIVED)
  description     String?
  sourceReference String?
  rawPayload      Json?
  rejectionReason String?
  whtApplicable       Boolean                @default(false)
  whtRate             Decimal?
  whtAmount           Decimal?
  netPayable          Decimal?

  supplierEmail       String?
  supplierBankName    String?
  supplierBankAccount String?
  supplierBankAccName String?

  amountPaid          Decimal?
  paymentReference    String?
  paymentProvider     String?
  paidAt              DateTime?
  paymentNotes        String?

  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  items           IncomingInvoiceItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([supplierTin])
  @@unique([tenantId, invoiceNumber, supplierTin])
  @@map("incoming_invoices")
}

model IncomingInvoiceItem {
  id                String          @id @default(uuid())
  incomingInvoiceId String
  description       String
  quantity          Decimal
  unitPrice         Decimal
  lineAmount        Decimal
  vatAmount         Decimal         @default(0)
  hsnCode           String?

  invoice           IncomingInvoice @relation(fields: [incomingInvoiceId], references: [id], onDelete: Cascade)

  @@index([incomingInvoiceId])
  @@map("incoming_invoice_items")
}

// ── VAT RECONCILIATION ────────────────────────────────────────────────────────

enum VatType {
  OUTPUT
  INPUT
}

enum VatEntryStatus {
  UNRECONCILED
  RECONCILED
  DISPUTED
  EXEMPT
}

enum VatPeriodStatus {
  OPEN
  CLOSED
  FILED
}

model VatEntry {
  id                String         @id @default(uuid())
  tenantId          String
  type              VatType
  invoiceId         String?
  incomingInvoiceId String?
  supplierTin       String?
  buyerTin          String?
  taxableAmount     Decimal
  vatAmount         Decimal
  vatRate           Decimal        @default(7.5)
  invoiceDate       DateTime
  period            String
  status            VatEntryStatus @default(UNRECONCILED)
  reconciledAt      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId, period])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("vat_entries")
}

model VatPeriodSummary {
  id                String          @id @default(uuid())
  tenantId          String
  period            String
  outputVat         Decimal         @default(0)
  inputVat          Decimal         @default(0)
  netVat            Decimal         @default(0)
  outputCount       Int             @default(0)
  inputCount        Int             @default(0)
  unreconciledCount Int             @default(0)
  status            VatPeriodStatus @default(OPEN)
  closedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant            Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("vat_period_summaries")
}

// ── FIRS REFERENCE DATA ───────────────────────────────────────────────────────

model InvoiceType {
  code      String   @id
  value     String
  createdAt DateTime @default(now())

  @@map("invoice_types")
}

model PaymentMeans {
  code      String   @id
  value     String
  createdAt DateTime @default(now())

  @@map("payment_means")
}

model TaxCategory {
  code      String   @id
  value     String
  createdAt DateTime @default(now())

  @@map("tax_categories")
}

model Currency {
  code          String   @id
  name          String
  symbol        String
  symbolNative  String
  decimalDigits Int      @default(2)
  rounding      Float    @default(0)
  namePlural    String
  createdAt     DateTime @default(now())

  @@map("currencies")
}

model HsCode {
  code        String   @id
  description String
  createdAt   DateTime @default(now())

  @@index([description])
  @@map("hs_codes")
}

model ServiceCode {
  code        String   @id
  description String
  createdAt   DateTime @default(now())

  @@index([description])
  @@map("service_codes")
}

model NigerianState {
  code      String   @id
  name      String
  lgas      Lga[]
  createdAt DateTime @default(now())

  @@map("nigerian_states")
}

model Lga {
  code      String        @id
  name      String
  stateCode String
  state     NigerianState @relation(fields: [stateCode], references: [code])
  createdAt DateTime      @default(now())

  @@index([stateCode])
  @@map("lgas")
}

model Country {
  alpha2      String   @id
  alpha3      String
  name        String
  countryCode String
  region      String?
  subRegion   String?
  createdAt   DateTime @default(now())

  @@index([name])
  @@map("countries")
}

model QuantityCode {
  code        String   @id
  name        String
  description String?
  createdAt   DateTime @default(now())

  @@map("quantity_codes")
}

model Client {
  id                  String    @id @default(uuid())
  tenantId            String
  companyName         String
  tin                 String?
  email               String?
  telephone           String?
  businessDescription String?
  contactPerson       String?
  notes               String?
  postalAddress       Json?

  totalInvoices       Int       @default(0)
  totalBilled         Decimal   @default(0)
  lastInvoiceAt       DateTime?

  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant              Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, companyName])
  @@unique([tenantId, tin])
  @@map("clients")
}